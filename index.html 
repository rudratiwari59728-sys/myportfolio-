<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rudra Developer</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{
background:#0f172a;
color:white;
}

/* Navbar */

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 10%;
background:#020617;
position:sticky;
top:0;
}

nav h2{
color:#38bdf8;
}

nav ul{
display:flex;
list-style:none;
}

nav ul li{
margin-left:20px;
}

nav ul li a{
text-decoration:none;
color:white;
font-weight:bold;
}

/* Hero Section */

.hero{
height:90vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
}

.hero h1{
font-size:50px;
}

.hero span{
color:#38bdf8;
}

.hero p{
margin-top:10px;
font-size:18px;
}

.hero button{
margin-top:20px;
padding:10px 25px;
border:none;
background:#38bdf8;
color:black;
font-weight:bold;
border-radius:5px;
cursor:pointer;
}

/* About */

.about{
padding:80px 10%;
text-align:center;
}

.about h2{
margin-bottom:20px;
font-size:35px;
color:#38bdf8;
}

/* Projects */

.projects{
padding:80px 10%;
}

.projects h2{
text-align:center;
margin-bottom:40px;
color:#38bdf8;
}

.project-container{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.project{
background:#1e293b;
padding:20px;
border-radius:10px;
transition:0.3s;
}

.project:hover{
transform:scale(1.05);
}

.project h3{
margin-bottom:10px;
}

/* Contact */

.contact{
padding:80px 10%;
text-align:center;
}

.contact h2{
margin-bottom:20px;
color:#38bdf8;
}

.contact input,
.contact textarea{
width:100%;
max-width:500px;
padding:10px;
margin:10px;
border:none;
border-radius:5px;
}

.contact button{
padding:10px 30px;
border:none;
background:#38bdf8;
font-weight:bold;
cursor:pointer;
border-radius:5px;
}

/* Footer */

footer{
text-align:center;
padding:20px;
background:#020617;
margin-top:40px;
}

</style>
</head>

<body>

<nav>
<h2>RudraDev</h2>

<ul>
<li><a href="#">Home</a></li>
<li><a href="#about">About</a></li>
<li><a href="#projects">Projects</a></li>
<li><a href="#contact">Contact</a></li>
</ul>

</nav>

<section class="hero">

<h1>Hello, I'm <span>Rudra Tiwari</span></h1>
<p>Full Stack Developer | Python | Django | JavaScript</p>

<button onclick="scrollToContact()">Hire Me</button>

</section>

<section class="about" id="about">

<h2>About Me</h2>

<p>
I am a passionate full stack developer who loves building websites and web applications.
I work with HTML, CSS, JavaScript, Python and Django to create modern websites.
My goal is to become a professional software developer.
</p>

</section>

<section class="projects" id="projects">

<h2>My Projects</h2>

<div class="project-container">

<div class="project">
<h3>Portfolio Website</h3>
<p>My personal developer portfolio website.</p>
</div>

<div class="project">
<h3>Calculator</h3>
<p>A simple calculator made with JavaScript.</p>
</div>

<div class="project">
<h3>To Do App</h3>
<p>Task management app using JavaScript.</p>
</div>

<div class="project">
<h3>Django Blog</h3>
<p>Blog website built with Django framework.</p>
</div>

</div>

</section>

<section class="contact" id="contact">

<h2>Contact Me</h2>

<input type="text" placeholder="Your Name"><br>
<input type="email" placeholder="Your Email"><br>
<textarea rows="5" placeholder="Your Message"></textarea><br>

<button>Send Message</button>

</section>

<footer>

<p>© 2026 Rudra Developer | All Rights Reserved</p>

</footer>

<script>

function scrollToContact(){
document.getElementById("contact").scrollIntoView({behavior:"smooth"});
}

</script>

</body>
</html>